// ==========================================
// SIMPLE FACTORY PATTERN
// Example: Burger Factory
// ==========================================


// Step 1: Define a common interface for all burgers
INTERFACE Burger

    // Method to prepare a burger
    METHOD prepare()

END INTERFACE


// Step 2: Create concrete burger classes

CLASS BasicBurger IMPLEMENTS Burger

    METHOD prepare()

        PRINT "Preparing Basic Burger with bun, patty, and ketchup!"

END CLASS


CLASS StandardBurger IMPLEMENTS Burger

    METHOD prepare()

        PRINT "Preparing Standard Burger with bun, patty, cheese, and lettuce!"

END CLASS


CLASS PremiumBurger IMPLEMENTS Burger

    METHOD prepare()

        PRINT "Preparing Premium Burger with gourmet bun, premium patty,"
              + " cheese, lettuce, and secret sauce!"

END CLASS


// Step 3: Create the Factory
// The factory decides which burger object to create.
CLASS BurgerFactory

    METHOD createBurger(type)

        IF type = "basic" THEN

            RETURN NEW BasicBurger()

        ELSE IF type = "standard" THEN

            RETURN NEW StandardBurger()

        ELSE IF type = "premium" THEN

            RETURN NEW PremiumBurger()

        ELSE

            PRINT "Invalid burger type!"
            RETURN NULL

        END IF

END CLASS


// ==========================================
// CLIENT CODE
// ==========================================
MAIN

    // Customer chooses a burger type
    burgerType ← "standard"

    // Create the factory object
    burgerFactory ← NEW BurgerFactory()

    // Ask factory to create the required burger
    burger ← burgerFactory.createBurger(burgerType)

    // If a valid burger is returned,
    // prepare the burger
    IF burger IS NOT NULL THEN

        burger.prepare()

    END IF

END MAIN
